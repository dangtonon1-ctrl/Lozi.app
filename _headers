# Cloudflare Pages / Workers Assets header rules.
# The app is now split into thin HTML shells (index.html, admin.html) plus
# modular JS/CSS under /src. The shells AND their /src assets use stable
# filenames (no content hashing), so both must be revalidated on every load —
# otherwise a new deploy could serve fresh HTML alongside a stale cached
# script/style. max-age=0 + must-revalidate makes the browser send a conditional
# request every load (fast 304 when unchanged, fresh 200 right after a deploy).
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/admin.html
  Cache-Control: public, max-age=0, must-revalidate
/src/*
  Cache-Control: public, max-age=0, must-revalidate
