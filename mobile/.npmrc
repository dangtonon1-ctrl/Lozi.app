# EAS Build runs a strict `npm ci` on its servers, which hard-fails on a
# web-only peer conflict: react-dom@19.2.7 (via expo-router → vaul/radix,
# never bundled into the native app) wants react@^19.2.7, while the scaffold
# pins react@19.2.3. Same lockfile tree installs either way — this just stops
# npm from rejecting it. Remove once the template's react/react-dom align.
legacy-peer-deps=true
