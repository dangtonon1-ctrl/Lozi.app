# Supabase connection for the Lozi mobile app.
# Copy this file to `.env` (in mobile/) and fill in the two values, then start
# Expo. `.env` is git-ignored; app.config.ts reads these into expo.extra.
#
# SUPABASE_ANON_KEY takes the modern *publishable* key (sb_publishable_...),
# NOT the legacy JWT anon key. The frozen web app keeps the legacy key, so the
# two rotate independently — revoking one never breaks the other. Both are
# public client keys, safe to expose by design.
SUPABASE_URL=
SUPABASE_ANON_KEY=
